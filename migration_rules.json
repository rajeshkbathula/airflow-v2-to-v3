  "reserved_keywords": {
    "_description": "Names that conflict or are reserved in Airflow 3",
    "items": [
      {"keyword": "utils", "issue": "airflow.utils is a core module - custom modules named 'utils' at the DAG bundle root can shadow it"},
      {"keyword": "models", "issue": "airflow.models is a core module - avoid naming custom packages 'models'"},
      {"keyword": "operators", "issue": "airflow.operators is a core module - avoid naming custom packages 'operators'"},
      {"keyword": "sensors", "issue": "airflow.sensors is a core module - avoid naming custom packages 'sensors'"},
      {"keyword": "hooks", "issue": "airflow.hooks is a core module - avoid naming custom packages 'hooks'"}
    ],
    "notes": "With DAG bundles in Airflow 3, the bundle root is added to the import path. Any directory at the bundle root that shares a name with an Airflow core module (utils, models, operators, sensors, hooks) will shadow that module, causing import failures."
  },

  "behavioral_changes": {
    "_description": "Behavior changes that don't involve API/import changes but affect DAG execution",
    "items": [
      {"change": "on_success_callback no longer fires for skipped tasks"},
      {"change": "max_active_runs evaluated per-run instead of across all runs"},
      {"change": "Connection.extra must be valid JSON (validation enforced)"},
      {"change": "DAG.tags changed from list to MutableSet (no duplicates, unordered)"},
      {"change": "Dataset/DatasetAlias no longer hashable (cannot use as dict keys or in sets)"},
      {"change": "Dataset equality now considers extra dict"},
      {"change": "All Param values must be JSON serializable"},
      {"change": "Parsed date/time Param values are now RFC3339 compliant"},
      {"change": "XCom pickling disabled by default (security)"},
      {"change": "Cron schedules now use CronTriggerTimetable by default instead of CronDataIntervalTimetable"},
      {"change": "logical_date semantics changed: now equals run_after instead of data_interval_start"},
      {"change": "logical_date can be None for asset-triggered or manually-triggered DAG runs"},
      {"change": "Minimum Pydantic version is 2.6.4"}
    ]
  },

