      "https://airflow.apache.org/docs/apache-airflow/3.0.0/installation/upgrading_to_airflow3.html",
      "https://docs.astral.sh/ruff/rules/airflow3-removal/",
      "https://docs.astral.sh/ruff/rules/airflow3-moved-to-provider/",
      "https://docs.astral.sh/ruff/rules/airflow3-suggested-update/",
