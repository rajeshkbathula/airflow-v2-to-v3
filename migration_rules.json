  "dag_definition_changes": {
    "_description": "Changes to how DAGs are defined",
    "constructor_changes": [
      {
        "change": "schedule_interval removed",
        "old": "DAG(dag_id='x', schedule_interval='@daily')",
        "new": "DAG(dag_id='x', schedule='@daily')"
      },
      {
        "change": "timetable parameter removed",
        "old": "DAG(dag_id='x', timetable=CronTimetable('0 * * * *'))",
        "new": "DAG(dag_id='x', schedule=CronTimetable('0 * * * *'))"
      },
      {
        "change": "fail_stop renamed to fail_fast",
        "old": "DAG(dag_id='x', fail_stop=True)",
        "new": "DAG(dag_id='x', fail_fast=True)"
      },
      {
        "change": "concurrency renamed",
        "old": "DAG(dag_id='x', concurrency=16)",
        "new": "DAG(dag_id='x', max_active_tasks=16)"
      }
    ],
    "decorator_changes": [
      {
        "change": "dag decorator moved to SDK",
        "old": "from airflow.decorators import dag",
        "new": "from airflow.sdk import dag"
      },
      {
        "change": "task decorator moved to SDK",
        "old": "from airflow.decorators import task",
        "new": "from airflow.sdk import task"
      },
      {
        "change": "task_group decorator moved to SDK",
        "old": "from airflow.decorators import task_group",
        "new": "from airflow.sdk import task_group"
      }
    ],
    "default_changes": [
      {"setting": "catchup", "old_default": "True", "new_default": "False"},
      {"setting": "schedule", "old_default": "timedelta(days=1)", "new_default": "None"},
      {"setting": "dag_ignore_file_syntax", "old_default": "regexp", "new_default": "glob"},
      {"setting": "cron interpretation", "old_default": "CronDataIntervalTimetable", "new_default": "CronTriggerTimetable"}
    ]
  },

